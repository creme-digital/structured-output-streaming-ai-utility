# Copy to .env.local and fill in for local development.
# These are the Supabase project's public URL + anon key (safe to expose client-side;
# data access is enforced by Postgres RLS, not by keeping this key secret).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NOTE: the OpenAI key is NOT a Vite/frontend variable. It is read server-side by the
# Netlify Edge Function at netlify/edge-functions/chat.ts via Deno.env.get("OPENAI_API_KEY").
# Set OPENAI_API_KEY in the Netlify site's Environment variables (and in `netlify dev`'s
# shell environment for local edge-function testing) — never in this file.
